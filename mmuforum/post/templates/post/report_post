{% load crispy_forms_tags %}

<html>
<body>
    <div class="container">
        <div class="header">
            <p><a href="{% url 'forum-main' %}">--back to mainpage</a></p>
            <h1>Report Post</h1>
        </div>

    <div class="report_post_card">
        <div class="report_post_title">Repost reason:</div>
        <form method="POST" enctype="multipart/form-data">
                {% csrf_token %}
                
                {{ form|crispy }}

                <div>
                    <button type="submit">Report</button>
                    <button type="reset">Clear Form</button>
                </div>
            </form>
        </div>

        <div>
                {% for post in posts %}
                    <div>
                        <h4>{{ post.title }}</h4>
                        <p><strong>Author:</strong> {{ post.author.username }}</p>
                        <p><strong>Posted:</strong> {{ post.date_posted|date:"Y-m-d H:i" }}</p>
                        <p>{{ post.content|linebreaks }}</p>
                        {% if post.image %}
                            <img src="{{ post.image.url }}" alt="Post Image" style="max-width: 200px;">
                        {% endif %}
                        <hr>
                    </div>
                {% empty %}
                    
                {% endfor %}

        </div>
    </div>
      
<script>

</script>
</body>
</html>
